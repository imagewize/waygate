{
  "name": "imagewize/waygate",
  "description": "AI-powered pattern page builder for the Elayne block theme",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "keywords": ["wordpress", "plugin", "patterns", "block-theme", "elayne", "ai"],
  "homepage": "https://github.com/imagewize/waygate",
  "authors": [
    {
      "name": "Jasper Frumau",
      "email": "jasper@imagewize.com",
      "homepage": "https://imagewize.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": ">=8.0",
    "composer/installers": "^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5 || ^10.0",
    "wp-coding-standards/wpcs": "^3.0",
    "squizlabs/php_codesniffer": "^3.8"
  },
  "autoload": {
    "classmap": ["includes/"]
  },
  "extra": {
    "installer-paths": {
      "../../plugins/{$name}/": ["type:wordpress-plugin"]
    }
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
