<?xml version="1.0"?>
<ruleset name="Waygate">
	<description>Waygate PHPCS configuration</description>

	<file>includes/</file>
	<file>waygate.php</file>

	<rule ref="WordPress">
		<!-- WordPress convention uses hyphens in file names for multi-word classes (e.g. class-pattern-lab.php) -->
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
	</rule>
</ruleset>
